{:name        "demo-corrupt"
 :workdir     "examples/demo"
 :lock        "examples/demo/.axiom.lock"
 :log-dir     "examples/demo/.axiom-logs-corrupt"
 :observers   {:level-count {:sh "ls level_*.txt 2>/dev/null | wc -l | tr -d ' '" :parse :int}
               :build-ok    {:sh "test -f .axiom-marker && echo pass || echo fail" :parse :string}}
 :goal        {:op :>= :ref :level-count :value 3}
 ;; integrity takes priority over stall; corrupt agent breaks the marker
 :integrity   [{:op := :ref :build-ok :value "pass"}]
 :progress    :level-count
 :act         {:sh "./corrupt.sh {{attempt}}"}
 :checkpoint  {:tag-prefix "axiom-corrupt"}
 :stall-after 5}
